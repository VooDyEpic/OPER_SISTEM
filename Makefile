# ============================================================================
# Makefile для лабораторной работы №1
# Параллельные процессы: fork(), pipe(), wait()
# ============================================================================

# ----------------------------------------------------------------------------
# Настройки компилятора
# ----------------------------------------------------------------------------
CC = gcc                      # Используемый компилятор
CFLAGS = -Wall -Wextra -O2    # Флаги компиляции:
                              #   -Wall     : все стандартные предупреждения
                              #   -Wextra   : дополнительные предупреждения
                              #   -O2       : уровень оптимизации (рекомендуемый)
LDFLAGS =                     # Флаги линковки (для fork/pipe ничего доп. не нужно)

# ----------------------------------------------------------------------------
# Структура проекта (простая, без разделения на папки для простоты)
# ----------------------------------------------------------------------------
TARGET = factorial_program    # Имя исполняемого файла

# Исходные файлы (все .c в текущей директории)
SRCS = main.c factorial.c

# Объектные файлы (заменяем .c на .o)
OBJS = $(SRCS:.c=.o)

# Общий ресурс (файл для синхронизации)
RESULT_FILE = result.txt

# ----------------------------------------------------------------------------
# Ассемблерные файлы для исследования оптимизаций
# ----------------------------------------------------------------------------
ASM_LEVELS = O0 O1 O2 O3 Os
ASM_MAIN = $(addprefix main_, $(addsuffix .s, $(ASM_LEVELS)))
ASM_FACT = $(addprefix factorial_, $(addsuffix .s, $(ASM_LEVELS)))
ASM_FILES = $(ASM_MAIN) $(ASM_FACT)

# ----------------------------------------------------------------------------
# Основные цели
# ----------------------------------------------------------------------------

# Цель по умолчанию: сборка программы
all: $(TARGET)

# Сборка исполняемого файла из объектных файлов
$(TARGET): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^ $(LDFLAGS)
	@echo "✅ Сборка завершена: $(TARGET)"

# Компиляция main.c -> main.o
main.o: main.c factorial.h
	$(CC) $(CFLAGS) -c main.c -o main.o

# Компиляция factorial.c -> factorial.o
factorial.o: factorial.c factorial.h
	$(CC) $(CFLAGS) -c factorial.c -o factorial.o

# ----------------------------------------------------------------------------
# Запуск программы
# ----------------------------------------------------------------------------

# Запуск программы
run: $(TARGET)
	@echo "🚀 Запуск программы:"
	@echo "============================================================"
	./$(TARGET)
	@echo "============================================================"

# Очистить и запустить заново
rerun: clean run

# ----------------------------------------------------------------------------
# Генерация ассемблерного кода (для исследования оптимизаций)
# ----------------------------------------------------------------------------

# Генерация всех ассемблерных файлов (O0, O1, O2, O3, Os)
asm-all: $(ASM_FILES)
	@echo "✅ Все ассемблерные файлы сгенерированы"

# Ассемблер для main.c с разными оптимизациями
main_O0.s: main.c
	$(CC) -S main.c -o main_O0.s -O0
main_O1.s: main.c
	$(CC) -S main.c -o main_O1.s -O1
main_O2.s: main.c
	$(CC) -S main.c -o main_O2.s -O2
main_O3.s: main.c
	$(CC) -S main.c -o main_O3.s -O3
main_Os.s: main.c
	$(CC) -S main.c -o main_Os.s -Os

# Ассемблер для factorial.c с разными оптимизациями
factorial_O0.s: factorial.c
	$(CC) -S factorial.c -o factorial_O0.s -O0
factorial_O1.s: factorial.c
	$(CC) -S factorial.c -o factorial_O1.s -O1
factorial_O2.s: factorial.c
	$(CC) -S factorial.c -o factorial_O2.s -O2
factorial_O3.s: factorial.c
	$(CC) -S factorial.c -o factorial_O3.s -O3
factorial_Os.s: factorial.c
	$(CC) -S factorial.c -o factorial_Os.s -Os

# Генерация для конкретного уровня (пример: make asm-O2)
asm-O0: main_O0.s factorial_O0.s
asm-O1: main_O1.s factorial_O1.s
asm-O2: main_O2.s factorial_O2.s
asm-O3: main_O3.s factorial_O3.s
asm-Os: main_Os.s factorial_Os.s

# ----------------------------------------------------------------------------
# Очистка проекта
# ----------------------------------------------------------------------------

# Очистка: удаление объектных файлов и исполняемого файла
clean:
	rm -f $(OBJS) $(TARGET)
	@echo "🧹 Удалены объектные файлы и $(TARGET)"

# Удаление всех ассемблерных файлов
clean-asm:
	rm -f $(ASM_FILES)
	@echo "🧹 Удалены ассемблерные файлы"

# Удаление файла-результата (общего ресурса)
clean-result:
	rm -f $(RESULT_FILE)
	@echo "🧹 Удалён $(RESULT_FILE)"

# Полная очистка (всё)
clean-all: clean clean-asm clean-result
	@echo "🧹 Полная очистка завершена"

# ----------------------------------------------------------------------------
# Отладочные цели
# ----------------------------------------------------------------------------

# Сборка с отладочной информацией (без оптимизации)
debug: CFLAGS = -Wall -Wextra -O0 -g
debug: clean $(TARGET)
	@echo "🐛 Отладочная сборка завершена"

# Показать содержимое файла-результата (общего ресурса)
show-result:
	@if [ -f $(RESULT_FILE) ]; then \
		echo "📄 Содержимое $(RESULT_FILE):"; \
		cat $(RESULT_FILE); \
	else \
		echo "❌ Файл $(RESULT_FILE) не существует. Запустите программу (make run)"; \
	fi

# Показать версию компилятора
version:
	$(CC) --version

# ----------------------------------------------------------------------------
# Справка
# ----------------------------------------------------------------------------

help:
	@echo "============================================================"
	@echo "📚 Доступные команды make:"
	@echo "============================================================"
	@echo ""
	@echo "🔨 СБОРКА:"
	@echo "  make           - собрать программу"
	@echo "  make debug     - собрать с отладочной информацией (-g -O0)"
	@echo ""
	@echo "▶️  ЗАПУСК:"
	@echo "  make run       - собрать и запустить программу"
	@echo "  make rerun     - очистить, собрать и запустить"
	@echo ""
	@echo "📝 АССЕМБЛЕР (для исследования оптимизаций):"
	@echo "  make asm-all   - сгенерировать все ассемблерные файлы (O0..Os)"
	@echo "  make asm-O2    - только для уровня O2"
	@echo "  make clean-asm - удалить ассемблерные файлы"
	@echo ""
	@echo "🧹 ОЧИСТКА:"
	@echo "  make clean      - удалить объектные файлы и программу"
	@echo "  make clean-all  - полная очистка (+ ассемблер + result.txt)"
	@echo "  make clean-result - удалить result.txt"
	@echo ""
	@echo "🔍 ОТЛАДКА/ПРОСМОТР:"
	@echo "  make show-result - показать содержимое result.txt"
	@echo "  make version     - показать версию компилятора"
	@echo ""
	@echo "============================================================"

# ----------------------------------------------------------------------------
# Фиктивные цели (не связаны с реальными файлами)
# ----------------------------------------------------------------------------
.PHONY: all run rerun clean clean-asm clean-result clean-all \
        asm-all asm-O0 asm-O1 asm-O2 asm-O3 asm-Os \
        debug show-result version help